<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Write New Chats</title>
    <link rel="stylesheet" href="/style.css"> 
</head>
<body>
    <div class="whatsapp-layout">
        
        <header class="app-top-bar">
            <div class="left-section">
                <div class="app-title-info">
                    <h3>New Chat</h3>
                    <span class="status-online" style="color: #cbd5e1; font-size: 0.75rem;">Create Mode</span>
                </div>
            </div>
        </header>

        <div style="padding: 20px; display: flex; flex-direction: column; gap: 15px; flex: 1;">
            
            <form method="post" action="/chats" style="display: flex; flex-direction: column; gap: 15px; background: #ffffff; padding: 20px; border-radius: 12px; box-shadow: 0 1px 2px rgba(0,0,0,0.1);">
                
                <div style="display: flex; flex-direction: column; gap: 6px;">
                    <label style="font-size: 0.85rem; font-weight: 600; color: #111b21;">Sender:</label>
                    <input type="text" placeholder="Who are you?" name="from" required style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #e1f5fe; font-size: 0.92rem; outline: none;" />
                </div>

                <div style="display: flex; flex-direction: column; gap: 6px;">
                    <label style="font-size: 0.85rem; font-weight: 600; color: #111b21;">Receiver:</label>
                    <input type="text" placeholder="add receiver" name="to" required style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #e1f5fe; font-size: 0.92rem; outline: none;" />
                </div>
                
                <div style="display: flex; flex-direction: column; gap: 6px;">
                    <label style="font-size: 0.85rem; font-weight: 600; color: #111b21;">Message:</label>
                    <textarea name="msg" rows="4" placeholder="Write your message here..." required style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #e1f5fe; font-size: 0.92rem; resize: none; outline: none; font-family: inherit; line-height: 1.4; color: #111b21;"></textarea>
                </div>
                
                <div style="display: flex; gap: 10px; align-items: center; justify-content: flex-end; margin-top: 5px;">
                    <a href="/chats" class="icon-btn delete-btn" style="text-decoration: none; padding: 8px 12px; font-weight: 600;">
                        Cancel
                    </a>
                    <button class="btn-new-chat" style="padding: 8px 16px; border-radius: 8px;">
                        Create Chat!
                    </button>
                </div>

            </form>
        </div>

    </div>
</body>
</html>